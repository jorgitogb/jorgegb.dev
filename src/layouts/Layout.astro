---
import '../styles/global.css';

interface Props {
  canonicalUrl?: string;
}

const { canonicalUrl = 'https://jorgegb.dev/' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Jorge GB - Software Developer</title>
    <meta name="description" content="Portfolio of Jorge GB, Software Developer at Plant Science Institute" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalUrl} />
  </head>
  <body class="bg-background text-primary-text">
    <div class="min-h-screen flex flex-col">
      <slot />
    </div>
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return 'light';
      })();
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
      window.localStorage.setItem('theme', theme);
    </script>
  </body>
</html>