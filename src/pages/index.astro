---
import Layout from '../layouts/Layout.astro';
---

<Layout>
      <header class="bg-surface border-b border-gray-200">
        <div class="container flex justify-between items-center">
          <div class="flex items-center gap-2">
            <div class="w-10 h-10 rounded-full bg-primary-blue flex items-center justify-center text-white font-bold">
              J
            </div>
            <h1 class="text-xl font-bold">Jorge García Brizuela</h1>
          </div>

          <button id="theme-toggle" class="p-2" aria-label="Toggle theme">
            <svg id="sun-icon" class="hidden dark:block" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="5"></circle>
              <line x1="12" y1="1" x2="12" y2="3"></line>
              <line x1="12" y1="21" x2="12" y2="23"></line>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
              <line x1="1" y1="12" x2="3" y2="12"></line>
              <line x1="21" y1="12" x2="23" y2="12"></line>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
            </svg>
            <svg id="moon-icon" class="block dark:hidden" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
          </button>

          <button id="mobile-menu-btn" class="md:hidden p-2" aria-label="Toggle menu">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="3" y1="12" x2="21" y2="12"></line>
              <line x1="3" y1="6" x2="21" y2="6"></line>
              <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
          </button>

          <nav id="mobile-menu" class="hidden md:block absolute md:static top-16 md:top-0 left-0 right-0 bg-surface md:bg-transparent border-b md:border-b-0">
            <ul class="flex flex-col md:flex-row gap-4 md:gap-6 p-4 md:p-0">
              <li><a href="#about" class="block hover:underline transition-colors">About</a></li>
              <li><a href="#experience" class="block hover:underline transition-colors">Experience</a></li>
              <li><a href="#skills" class="block hover:underline transition-colors">Skills</a></li>
              <li><a href="#projects" class="block hover:underline transition-colors">Projects</a></li>
              <li><a href="#publications" class="block hover:underline transition-colors">Publications</a></li>
              <li><a href="#connect" class="block hover:underline transition-colors">Connect</a></li>
            </ul>
          </nav>
        </div>
      </header>

      <main>
        <section class="section bg-surface">
          <div class="container text-center py-16">
              <h1 class="text-4xl md:text-5xl font-bold mb-6">Jorge Garcia Brizuela</h1>
              <p class="text-xl mb-8 text-secondary-text">
                Software Developer at Plant Science Institute
              </p>
              <p class="mb-10 text-lg">
                Bridging the gap between technology and plant science research through innovative software solutions.
              </p>
              <div class="flex justify-center gap-4">
                <a href="#about" class="btn btn-primary">Learn More</a>
                <a href="#contact" class="btn btn-secondary">Contact Me</a>
              </div>
          </div>
        </section>

        <section id="about" class="section bg-surface">
          <div class="container">
            <h2 class="section-title">About Me</h2>
            <div class="grid md:grid-cols-2 gap-8 items-center">
              <div>
                <h3 class="text-2xl font-semibold mb-4">Professional Background</h3>
                <p class="mb-4">
                  I am a software developer working at a plant science institute, where I combine my technical expertise 
                  with scientific research to develop innovative solutions for agricultural and botanical studies.
                </p>
                <p class="mb-4">
                  My work involves creating data management systems, analytical tools, and research applications that 
                  support cutting-edge plant science research and contribute to sustainable agriculture initiatives.
                </p>
                <p>
                  With a strong foundation in both computer science and biological sciences, I bridge the gap between 
                  technical development and scientific discovery.
                </p>
              </div>
              <div class="flex justify-center">
                <div class="w-64 h-64 rounded-full bg-primary-blue flex items-center justify-center text-white text-6xl font-bold">
                  J
                </div>
              </div>
            </div>
          </div>
        </section>

        <section id="experience" class="section bg-muted-surface">
          <div class="container">
            <h2 class="section-title">Experience</h2>
            <div class="space-y-8">
              <div class="card">
                <h3 class="text-xl font-semibold mb-2">Software Developer</h3>
                <p class="text-primary-blue font-medium mb-2">Plant Science Institute</p>
                <p class="text-secondary-text mb-4">2020 - Present</p>
                <ul class="list-disc pl-5 space-y-2">
                  <li>Developed custom data management systems for plant research databases</li>
                  <li>Created analytical tools for genomic and phenotypic data analysis</li>
                  <li>Designed and implemented web applications for collaborative research</li>
                  <li>Worked with researchers to translate scientific requirements into technical solutions</li>
                </ul>
              </div>
              
              <div class="card">
                <h3 class="text-xl font-semibold mb-2">Previous Roles</h3>
                <p class="text-secondary-text mb-4">Various software development positions</p>
                <ul class="list-disc pl-5 space-y-2">
                  <li>Full-stack development for enterprise applications</li>
                  <li>Database design and optimization for scientific datasets</li>
                  <li>Research and prototyping of novel software solutions</li>
                </ul>
              </div>
            </div>
          </div>
        </section>

        <section id="skills" class="section bg-surface">
          <div class="container">
            <h2 class="section-title">Technical Skills</h2>
            <div class="grid md:grid-cols-3 gap-8">
              <div class="card">
                <h3 class="text-xl font-semibold mb-4 text-primary-blue">Programming Languages</h3>
                <ul class="space-y-2">
                  <li class="flex items-center gap-2">
                    <span class="w-3 h-3 rounded-full bg-primary-blue"></span>
                    SQL
                  </li>
                  <li class="flex items-center gap-2">
                    <span class="w-3 h-3 rounded-full bg-primary-blue"></span>
                    Python
                  </li>
                  <li class="flex items-center gap-2">
                    <span class="w-3 h-3 rounded-full bg-primary-blue"></span>
                    TypeScript
                  </li>
                  <li class="flex items-center gap-2">
                    <span class="w-3 h-3 rounded-full bg-primary-blue"></span>
                    JavaScript
                  </li>
                  <li class="flex items-center gap-2">
                    <span class="w-3 h-3 rounded-full bg-primary-blue"></span>
                    Go
                  </li>
                </ul>
              </div>
              
              <div class="card">
                <h3 class="text-xl font-semibold mb-4 text-secondary-green">Frameworks</h3>
                <ul class="space-y-2">
                  <li class="flex items-center gap-2">
                    <span class="w-3 h-3 rounded-full bg-secondary-green"></span>
                    React
                  </li>
                  <li class="flex items-center gap-2">
                    <span class="w-3 h-3 rounded-full bg-secondary-green"></span>
                    FastAPI
                  </li>
                  <li class="flex items-center gap-2">
                    <span class="w-3 h-3 rounded-full bg-secondary-green"></span>
                    Oracle APEX
                  </li>
                </ul>
              </div>
              
              <div class="card">
                <h3 class="text-xl font-semibold mb-4 text-accent-yellow">Databases</h3>
                <ul class="space-y-2">
                  <li class="flex items-center gap-2">
                    <span class="w-3 h-3 rounded-full bg-accent-yellow"></span>
                    Oracle
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </section>

        <section id="projects" class="section bg-muted-surface">
          <div class="container">
            <h2 class="section-title">Projects</h2>
            <div class="grid md:grid-cols-2 gap-8">
              <div class="card">
                <h3 class="text-xl font-semibold mb-2">Plant Data Management System</h3>
                <p class="text-secondary-text mb-4">Custom database solution for plant research data</p>
                <p class="mb-4">
                  Developed a comprehensive system for managing large-scale plant phenotypic and genotypic datasets.
                </p>
                <a href="#" class="text-primary-blue hover:underline">View on GitHub</a>
              </div>
              
              <div class="card">
                <h3 class="text-xl font-semibold mb-2">Phenotyping Analysis Tool</h3>
                <p class="text-secondary-text mb-4">Web application for plant image analysis</p>
                <p class="mb-4">
                  Created a web-based tool that enables researchers to analyze plant growth patterns from images.
                </p>
                <a href="#" class="text-primary-blue hover:underline">View on GitHub</a>
              </div>
              
              <div class="card">
                <h3 class="text-xl font-semibold mb-2">Genomic Data Pipeline</h3>
                <p class="text-secondary-text mb-4">Automated workflow for genomic data processing</p>
                <p class="mb-4">
                  Built a scalable pipeline for processing and analyzing genomic data from plant research projects.
                </p>
                <a href="#" class="text-primary-blue hover:underline">View on GitHub</a>
              </div>
              
              <div class="card">
                <h3 class="text-xl font-semibold mb-2">Research Dashboard</h3>
                <p class="text-secondary-text mb-4">Interactive visualization platform</p>
                <p class="mb-4">
                  Designed an interactive dashboard for visualizing research results and trends in plant science.
                </p>
                <a href="#" class="text-primary-blue hover:underline">View on GitHub</a>
              </div>
            </div>
          </div>
        </section>

        <section id="publications" class="section bg-surface">
          <div class="container">
            <h2 class="section-title">Scientific Publications</h2>
            <div class="space-y-6">
              <div class="card">
                <h3 class="text-xl font-semibold mb-2">Genomic Analysis of Drought Resistance in Wheat</h3>
                <p class="text-secondary-text mb-2">Journal of Plant Biology, 2023</p>
                <p class="mb-4">
                  Collaborative research on identifying genetic markers associated with drought tolerance in wheat varieties.
                </p>
                <a href="#" class="text-primary-blue hover:underline">View Publication</a>
              </div>
              
              <div class="card">
                <h3 class="text-xl font-semibold mb-2">Machine Learning Approaches for Phenotyping Crop Plants</h3>
                <p class="text-secondary-text mb-2">Agricultural Informatics, 2022</p>
                <p class="mb-4">
                  Application of computer vision techniques for automated phenotyping in crop breeding programs.
                </p>
                <a href="#" class="text-primary-blue hover:underline">View Publication</a>
              </div>
              
              <div class="card">
                <h3 class="text-xl font-semibold mb-2">Development of a Database System for Plant Genetics Research</h3>
                <p class="text-secondary-text mb-2">Plant Science Informatics, 2021</p>
                <p class="mb-4">
                  Description of database architecture designed for managing large-scale genetic datasets in plant research.
                </p>
                <a href="#" class="text-primary-blue hover:underline">View Publication</a>
              </div>
            </div>
          </div>
        </section>

        <section id="connect" class="section bg-muted-surface">
          <div class="container">
            <h2 class="section-title">Connect With Me</h2>
            <div class="grid md:grid-cols-2 gap-8">
              <div class="card">
                <h3 class="text-xl font-semibold mb-4">Professional Profiles</h3>
                <ul class="space-y-3">
                  <li class="flex items-center gap-3">
                    <span class="w-8 h-8 rounded-full bg-primary-blue flex items-center justify-center text-white">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20.24 12.24a6 6 0 0 0-8.48-8.48L5 10.5V19h8.5z"></path>
                        <polyline points="16 8 20 12 16 16"></polyline>
                      </svg>
                    </span>
                    <a href="#" class="text-primary-blue hover:underline">ORCID</a>
                  </li>
                  <li class="flex items-center gap-3">
                    <span class="w-8 h-8 rounded-full bg-primary-blue flex items-center justify-center text-white">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M15 22v-4m0 0V8a2 2 0 0 1 2-2h4l-1-1"></path>
                        <path d="M4 19h4v-4H4l4-4"></path>
                        <path d="M12 12v4h4"></path>
                        <circle cx="12" cy="12" r="10"></circle>
                      </svg>
                    </span>
                    <a href="#" class="text-primary-blue hover:underline">GitHub</a>
                  </li>
                  <li class="flex items-center gap-3">
                    <span class="w-8 h-8 rounded-full bg-primary-blue flex items-center justify-center text-white">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
                        <rect x="2" y="9" width="4" height="12"></rect>
                        <circle cx="4" cy="4" r="2"></circle>
                      </svg>
                    </span>
                    <a href="#" class="text-primary-blue hover:underline">LinkedIn</a>
                  </li>
                  <li class="flex items-center gap-3">
                    <span class="w-8 h-8 rounded-full bg-primary-blue flex items-center justify-center text-white">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.67 10.67 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path>
                      </svg>
                    </span>
                    <a href="#" class="text-primary-blue hover:underline">X (Twitter)</a>
                  </li>
                  <li class="flex items-center gap-3">
                    <span class="w-8 h-8 rounded-full bg-primary-blue flex items-center justify-center text-white">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 12c0 5.523-4.477 10-10 10S2 17.523 2 12 6.477 2 12 2s10 4.477 10 10z"></path>
                        <circle cx="12" cy="12" r="3"></circle>
                      </svg>
                    </span>
                    <a href="#" class="text-primary-blue hover:underline">Instagram</a>
                  </li>
                </ul>
              </div>
              
              <div class="card">
                <h3 class="text-xl font-semibold mb-4">Support My Work</h3>
                <p class="mb-4">
                  If you find my work valuable, consider supporting me through Buy Me A Coffee or by purchasing items from my wishlist.
                </p>
                <div class="space-y-3">
                  <a href="#" class="btn btn-primary w-full flex items-center justify-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M20.38 3.46L16 2a4 4 0 0 0-8 0l-4 1.46A2 2 0 0 0 2 7v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V7a2 2 0 0 0-1.62-1.54z"></path>
                      <path d="M12 8v4"></path>
                      <path d="M12 16h.01"></path>
                    </svg>
                    Buy Me A Coffee
                  </a>

                  <a href="#wishlist" class="btn btn-secondary w-full flex items-center justify-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="10"></circle>
                      <path d="M12 8v4"></path>
                      <path d="M12 16h.01"></path>
                    </svg>
                    View Wishlist
                  </a>
                </div>
              </div>
            </div>
          </div>
        </section>

        <section id="wishlist" class="section bg-muted-surface">
          <div class="container">
            <h2 class="section-title">Wishlist</h2>
            <p class="text-center text-secondary-text mb-8">
              Products I'm saving up for. Your support helps make these happen!
            </p>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
              <div class="card text-center p-4">
                <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-primary-blue flex items-center justify-center text-white">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="5"></circle>
                    <line x1="12" y1="1" x2="12" y2="3"></line>
                    <line x1="12" y1="21" x2="12" y2="23"></line>
                    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
                    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
                    <line x1="1" y1="12" x2="3" y2="12"></line>
                    <line x1="21" y1="12" x2="23" y2="12"></line>
                    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
                    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
                  </svg>
                </div>
                <h3 class="text-sm font-semibold">Xiaomi Light Bar</h3>
                <a href="https://www.amazon.de/Xiaomi-Computer-Lichtleiste-regulierbare-Farbtemperatur/dp/B08W2C5W59" target="_blank" rel="noopener" class="text-primary-blue hover:underline text-sm">View</a>
              </div>
              
              <div class="card text-center p-4">
                <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-secondary-green flex items-center justify-center text-white">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
                    <path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"></path>
                  </svg>
                </div>
                <h3 class="text-sm font-semibold">Xiaomi Speaker</h3>
                <a href="https://www.mi.com/de/product/xiaomi-desktop-speaker/" target="_blank" rel="noopener" class="text-primary-blue hover:underline text-sm">View</a>
              </div>
              
              <div class="card text-center p-4">
                <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-accent-yellow flex items-center justify-center text-white">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="4" width="20" height="16" rx="2" ry="2"></rect>
                    <path d="M6 8h.01"></path>
                    <path d="M10 8h.01"></path>
                    <path d="M14 8h.01"></path>
                    <path d="M18 8h.01"></path>
                    <path d="M6 12h.01"></path>
                    <path d="M18 12h.01"></path>
                    <path d="M6 16h12"></path>
                  </svg>
                </div>
                <h3 class="text-sm font-semibold">KZZI I75 Keyboard</h3>
                <a href="https://www.kzzistore.com/products/kzzi-i75-low-profile-mechanical-keyboard?variant=50794998858006" target="_blank" rel="noopener" class="text-primary-blue hover:underline text-sm">View</a>
              </div>
              
              <div class="card text-center p-4">
                <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-primary-blue flex items-center justify-center text-white">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 12c0 5.523-4.477 10-10 10S2 17.523 2 12 6.477 2 12 2"></path>
                    <path d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"></path>
                    <path d="M8 12h8"></path>
                    <path d="M12 8v8"></path>
                  </svg>
                </div>
                <h3 class="text-sm font-semibold">Magic Trackpad</h3>
                <a href="https://www.apple.com/de/shop/product/mxk93z/a/magic-trackpad-usb-c-weisse-multi-touch-oberflache" target="_blank" rel="noopener" class="text-primary-blue hover:underline text-sm">View</a>
              </div>
            </div>
          </div>
        </section>
      </main>

      <footer class="bg-surface border-t border-gray-200" style="padding-top: 1rem; padding-bottom: 1rem;">
        <div class="container text-center">
          <p class="text-secondary-text">
            © {new Date().getFullYear()} Jorge Garcia Brizuela. All rights reserved.
          </p>
          <p class="text-secondary-text">
            Built with Astro, React, and TypeScript
          </p>
        </div>
      </footer>
    </div>

    <script>
      const menuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const themeToggle = document.getElementById('theme-toggle');

      menuBtn?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden');
      });

      themeToggle?.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      });
    </script>
  </body>
</Layout>