---
import Layout from '../layouts/Layout.astro';
---

<Layout>
      <header class="bg-surface border-b border-gray-200">
        <div class="container flex justify-between items-center">
          <div class="flex items-center gap-2">
            <div class="w-10 h-10 rounded-full bg-primary-blue flex items-center justify-center text-white font-bold">
              J
            </div>
            <h1 class="text-xl font-bold">Jorge García Brizuela</h1>
          </div>

          <button id="theme-toggle" class="p-2" aria-label="Toggle theme">
            <svg id="sun-icon" class="hidden dark:block" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="5"></circle>
              <line x1="12" y1="1" x2="12" y2="3"></line>
              <line x1="12" y1="21" x2="12" y2="23"></line>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
              <line x1="1" y1="12" x2="3" y2="12"></line>
              <line x1="21" y1="12" x2="23" y2="12"></line>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
            </svg>
            <svg id="moon-icon" class="block dark:hidden" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
          </button>

          <button id="mobile-menu-btn" class="md:hidden p-2" aria-label="Toggle menu">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="3" y1="12" x2="21" y2="12"></line>
              <line x1="3" y1="6" x2="21" y2="6"></line>
              <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
          </button>

          <nav id="mobile-menu" class="hidden md:block absolute md:static top-16 md:top-0 left-0 right-0 bg-surface md:bg-transparent border-b md:border-b-0">
            <ul class="flex flex-col md:flex-row gap-4 md:gap-6 p-4 md:p-0">
              <li><a href="#about" class="block hover:underline transition-colors">About</a></li>
              <li><a href="#experience" class="block hover:underline transition-colors">Experience</a></li>
              <li><a href="#skills" class="block hover:underline transition-colors">Skills</a></li>
              <li><a href="#projects" class="block hover:underline transition-colors">Projects</a></li>
              <li><a href="#publications" class="block hover:underline transition-colors">Publications</a></li>
              <li><a href="#connect" class="block hover:underline transition-colors">Connect</a></li>
              <li><a href="/wishlist" class="block hover:underline transition-colors">Wishlist</a></li>
            </ul>
          </nav>
        </div>
      </header>

      <main>
        <section class="section bg-surface">
          <div class="container text-center py-16">
              <h1 class="text-4xl md:text-5xl font-bold mb-6">Jorge Garcia Brizuela</h1>
              <p class="text-xl mb-8 text-secondary-text">
                Software Developer at Plant Science Institute
              </p>
              <p class="mb-10 text-lg">
                Bridging the gap between technology and plant science research through innovative software solutions.
              </p>
              <div class="flex justify-center gap-4">
                <a href="#about" class="btn btn-primary">Learn More</a>
                <a href="#contact" class="btn btn-secondary">Contact Me</a>
              </div>
          </div>
        </section>

        <section id="about" class="section bg-surface">
          <div class="container">
            <h2 class="section-title">About Me</h2>
            <div class="grid md:grid-cols-2 gap-8 items-center">
              <div>
                <h3 class="text-2xl font-semibold mb-4">Professional Background</h3>
                <p class="mb-4">
                  I am a software developer working at a plant science institute, where I combine my technical expertise 
                  with scientific research to develop innovative solutions for agricultural and botanical studies.
                </p>
                <p class="mb-4">
                  My work involves creating data management systems, analytical tools, and research applications that 
                  support cutting-edge plant science research and contribute to sustainable agriculture initiatives.
                </p>
                <p>
                  With a strong foundation in both computer science and biological sciences, I bridge the gap between 
                  technical development and scientific discovery.
                </p>
              </div>
              <div class="flex justify-center">
                <div class="w-64 h-64 rounded-full bg-primary-blue flex items-center justify-center text-white text-6xl font-bold">
                  J
                </div>
</div>
            </div>
            <div class="text-center mt-8">
              <a href="/publications" class="btn btn-secondary">View All Publications</a>
            </div>
          </div>
        </section>

        <section id="connect" class="section bg-muted-surface">
          <div class="container">
            <h2 class="section-title">Connect With Me</h2>
            <div class="grid md:grid-cols-2 gap-8">
              <div class="card">
                <h3 class="text-xl font-semibold mb-4">Professional Profiles</h3>
                <ul class="space-y-3">
                  <li class="flex items-center gap-3">
                    <span class="w-10 h-10 rounded-full bg-[#A6CE39] flex items-center justify-center">
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="white">
                        <path d="M12 0C5.372 0 0 5.373 0 12s5.372 12 12 12 12-5.373 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947s-.422.947-.947.947-.947-.431-.947-.947.422-.947.947-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.025-5.325 5.025h-3.919V7.416zm1.444 1.303v7.444h2.297c2.359 0 3.994-1.547 3.994-3.722 0-2.016-1.397-3.722-3.994-3.722h-2.297z"/>
                      </svg>
                    </span>
                    <a href="https://orcid.org/0000-0003-0527-1339" target="_blank" rel="noopener" class="text-primary-blue hover:underline">ORCID</a>
                  </li>
                  <li class="flex items-center gap-3">
                    <span class="w-10 h-10 rounded-full bg-[#333] flex items-center justify-center">
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="white">
                        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                      </svg>
                    </span>
                    <a href="https://github.com/jorgitogb" target="_blank" rel="noopener" class="text-primary-blue hover:underline">GitHub</a>
                  </li>
                  <li class="flex items-center gap-3">
                    <span class="w-10 h-10 rounded-full bg-[#0077b5] flex items-center justify-center">
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="white">
                        <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                      </svg>
                    </span>
                    <a href="https://www.linkedin.com/in/jorge-garcia-brizuela-b56669aa/" target="_blank" rel="noopener" class="text-primary-blue hover:underline">LinkedIn</a>
                  </li>
                  <li class="flex items-center gap-3">
                    <span class="w-10 h-10 rounded-full bg-black flex items-center justify-center">
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="white">
                        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                      </svg>
                    </span>
                    <a href="https://x.com/jorge_garciab" target="_blank" rel="noopener" class="text-primary-blue hover:underline">X</a>
                  </li>
                  <li class="flex items-center gap-3">
                    <span class="w-10 h-10 rounded-full bg-[#E4405F] flex items-center justify-center">
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="white">
                        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                      </svg>
                    </span>
                    <a href="https://www.instagram.com/jgbrizuela/" target="_blank" rel="noopener" class="text-primary-blue hover:underline">Instagram</a>
                  </li>
                </ul>
              </div>
              
              <div class="card">
                <h3 class="text-xl font-semibold mb-4">Support My Work</h3>
                <p class="mb-4">
                  If you find my work valuable, consider supporting me through Buy Me A Coffee or by purchasing items from my wishlist.
                </p>
                <div class="space-y-3">
                  <a href="#" class="btn btn-primary w-full flex items-center justify-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M20.38 3.46L16 2a4 4 0 0 0-8 0l-4 1.46A2 2 0 0 0 2 7v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V7a2 2 0 0 0-1.62-1.54z"></path>
                      <path d="M12 8v4"></path>
                      <path d="M12 16h.01"></path>
                    </svg>
                    Buy Me A Coffee
                  </a>

                  <a href="/wishlist" class="btn btn-secondary w-full flex items-center justify-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="10"></circle>
                      <path d="M12 8v4"></path>
                      <path d="M12 16h.01"></path>
                    </svg>
                    View Wishlist
                  </a>
                </div>
              </div>
            </div>
          </div>
        </section>
      </main>

      <footer class="bg-surface border-t border-gray-200" style="padding-top: 1rem; padding-bottom: 1rem;">
        <div class="container text-center">
          <p class="text-secondary-text">
            © {new Date().getFullYear()} Jorge Garcia Brizuela. All rights reserved.
          </p>
          <p class="text-secondary-text">
            Built with Astro, React, and TypeScript
          </p>
        </div>
      </footer>
    </div>

    <script>
      const menuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const themeToggle = document.getElementById('theme-toggle');

      menuBtn?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden');
      });

      themeToggle?.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      });
    </script>
  </body>
</Layout>